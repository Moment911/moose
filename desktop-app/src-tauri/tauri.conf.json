{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KotoIQ",
  "version": "1.0.0",
  "identifier": "com.hellokoto.kotoiq",
  "build": {
    "frontendDist": "../src",
    "devUrl": "https://hellokoto.com/kotoiq"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KotoIQ",
        "url": "https://hellokoto.com/kotoiq",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "theme": "Light",
        "userAgent": "KotoIQ-Desktop/1.0 (Tauri)"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    },
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "KotoIQ — SEO Intelligence"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 KotoIQ. All rights reserved.",
    "category": "Business",
    "shortDescription": "AI-powered SEO intelligence platform",
    "longDescription": "KotoIQ is an AI-powered SEO command center with 21+ semantic intelligence agents, topical authority mapping, rank tracking, content generation, and local SEO intelligence. Built for agencies and in-house teams who need to rank #1.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "hellokoto.com",
      "entitlements": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": [
        "https://hellokoto.com/api/desktop/update/{{target}}/{{current_version}}"
      ]
    }
  }
}
