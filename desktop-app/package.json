{
  "name": "kotoiq-desktop",
  "version": "1.0.0",
  "description": "KotoIQ — AI-powered SEO intelligence desktop app",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:mac": "tauri build --target universal-apple-darwin",
    "build:mac-arm": "tauri build --target aarch64-apple-darwin",
    "build:mac-intel": "tauri build --target x86_64-apple-darwin",
    "build:win": "tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu --bundles deb",
    "build:linux-appimage": "tauri build --target x86_64-unknown-linux-gnu --bundles appimage"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0"
  }
}
